# Server
PORT=8787

# Naver Cloud CLOVA Studio
# 값을 브라우저 코드에 넣지 말고 서버 환경변수로만 사용한다.
# nv-... 형태나 Bearer nv-... 형태 모두 server.js에서 처리한다.
# CLOVA_STUDIO_API_KEY가 비어 있으면 로컬 데모 fallback으로 전환된다.
CLOVA_STUDIO_API_KEY=
CLOVA_STUDIO_REQUEST_ID=

# Ncloud Cloud DB for PostgreSQL
# 모두 비어 있으면 DB 없이 로컬 fallback으로 동작한다.
DB_DOMAIN=
DB_PORT=5432
DB_NAME=scholarship_radar
DB_USER_ID=
DB_USER_PASSWORD=
# SSL 연결 필요 시 true로 설정 (Ncloud DB는 보통 true)
DB_SSL=false
